// Claude Code Global Settings
//
// Installed to ~/.claude/settings.json by install.sh (copy, not symlink).
// Claude Code writes to this file when you approve permissions per-session,
// so it must be a real file, not a symlink.
//
// After modifying this template, re-run install.sh or manually copy:
//   cp ~/Projects/claude-code-toolkit/claude-md/settings-global.jsonc ~/.claude/settings.json
{
  "permissions": {
    "allow": [
      // ── File operations ───────────────────────────────────────
      // Write and Edit are always needed — without these, every file
      // modification triggers a permission prompt.
      "Write",
      "Edit",
      "MultiEdit",

      // ── Shell utilities ───────────────────────────────────────
      // Basic read-only commands. Low risk, constantly used during
      // codebase exploration.
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(echo *)",
      "Bash(printf *)",

      // ── File management ───────────────────────────────────────
      // Creating directories and copying/moving files. Needed for
      // project scaffolding and file organization.
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(chmod *)",
      "Bash(tee *)",

      // ── Git & GitHub ──────────────────────────────────────────
      // Core workflow tools. Destructive git operations (force push,
      // reset --hard) are caught by the block-destructive hook.
      "Bash(git *)",
      "Bash(gh *)",

      // ── Docker ────────────────────────────────────────────────
      "Bash(docker *)",

      // ── Node.js ───────────────────────────────────────────────
      "Bash(npm *)",
      "Bash(npx *)",

      // ── Python ────────────────────────────────────────────────
      // Direct python/ruff/uv invocations. For venv binaries, prefer
      // ~/.claude/bin/venv-run.sh (auto-detects venv).
      "Bash(python *)",
      "Bash(*/python *)",
      "Bash(ruff *)",
      "Bash(*/ruff *)",
      "Bash(uv *)",
      "Bash(*/uv *)",
      "Bash(source *)",

      // ── Toolkit ───────────────────────────────────────────────
      // Helper scripts and hooks from the toolkit's bin/ directory.
      "Bash(~/.claude/bin/*)",

      // ── System ────────────────────────────────────────────────
      "Bash(xdg-open *)",
      "Read(~/Pictures/Screenshots/**)",
      "Read(~/.claude/**)",

      // ── Temp files ────────────────────────────────────────────
      // Allow writing/editing temp files for commit messages, issue
      // bodies, and other intermediary files.
      "Write(/tmp/*)",
      "Edit(/tmp/*)"
    ],
    "deny": [
      // ── Destructive operations ────────────────────────────────
      // Hard deny — Claude will warn and ask for confirmation.
      // The block-destructive hook provides additional pattern-based
      // protection (force push, reset --hard, DROP TABLE, etc.).
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)"
    ],
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "alwaysThinkingEnabled": true,

  // ── Hooks ───────────────────────────────────────────────────────
  // Pre-tool hooks run BEFORE a tool executes. They work in ALL
  // permission modes, including bypass-permissions.
  //
  // auto-approve: approves safe compound commands (redirects, pipes,
  //   && chains, for loops) that permission matching would block.
  // block-destructive: catches dangerous patterns (force push,
  //   rm -rf, DROP TABLE, etc.). Exit code 2 = block.
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/bin/hook-auto-approve-bash.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/bin/hook-block-destructive.sh"
          }
        ]
      }
    ]
  }
}
